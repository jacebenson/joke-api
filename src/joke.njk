---
pagination:
    data: jokes.all
    size: 1
    alias: joke
permalink: "/{{ pagination.pageNumber }}/"
---
{% extends site.getFile("/layouts/base.njk") %}

{% block title %}{{ joke.joke }}{% endblock title %}

{% block content %}
<script>
function randomJoke(total) {
  const id = Math.floor(Math.random() * total);
  window.location.href = '/' + id;
}

function shareJoke() {
  const jokeText = document.getElementById('text').innerText;
  const punchlineText = document.querySelector('.punchline')?.innerText || '';
  const fullText = punchlineText ? jokeText + '\n\n' + punchlineText : jokeText;
  
  if (navigator.share) {
    navigator.share({
      title: 'Joke from joke.jace.pro',
      text: fullText,
      url: window.location.href
    }).catch(err => console.log('Share cancelled'));
  } else {
    navigator.clipboard.writeText(fullText + '\n\n' + window.location.href).then(() => {
      alert('Joke copied to clipboard!');
    });
  }
}
</script>

<div class="container">
  <!-- Actions on top -->
  <div class="actions-top">
    <button class="btn btn-secondary" onclick="shareJoke()">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="18" cy="5" r="3"/>
        <circle cx="6" cy="12" r="3"/>
        <circle cx="18" cy="19" r="3"/>
        <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
        <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
      </svg>
      Share
    </button>
    
    <button class="btn btn-primary" onclick="randomJoke({{ jokes.all.length }})">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
        <path d="M3 3v5h5"/>
        <path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/>
        <path d="M16 21h5v-5"/>
      </svg>
      Next Joke
    </button>
  </div>
  
  <!-- Joke Display below -->
  <div class="joke-content">
    <div id="text">{{ joke.joke }}</div>
    {% if joke.punchline %}
    <div class="punchline">{{ joke.punchline }}</div>
    {% endif %}
  </div>
  
  <!-- Joke ID at bottom -->
  <div class="joke-meta">
    <span>Joke #{{ pagination.pageNumber }} of {{ jokes.all.length }}</span>
    <a href="/api/{{ pagination.pageNumber }}.json">API</a>
  </div>
</div>
{% endblock content %}
